rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }
    
    function isAdmin() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isParent() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "parent";
    }

    function isKid() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "kid";
    }

    function isParentOfChild(childId) {
      return isParent()
        && exists(/databases/$(database)/documents/children/$(childId))
        && get(/databases/$(database)/documents/children/$(childId)).data.linkedParentUid == request.auth.uid;
    }

    // Users Collection (Profile Data)
    match /users/{userId} {
      allow read: if isOwner(userId)
        || isAdmin()
        || (
          isParent()
          && resource.data.role == "kid"
          && resource.data.linkedParentUid == request.auth.uid
        );
      allow write: if isOwner(userId);
    }

    // Children Profile Collection
    match /children/{childId} {
      allow read: if isOwner(childId) || isParentOfChild(childId) || isAdmin();
      allow create, update: if isOwner(childId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Child credentials are server-only. They must contain hashed secrets only.
    match /childCredentials/{loginIdLower} {
      allow read, write: if false;
    }

    // Gamification Collection
    match /gamification/{userId} {
      allow read: if isOwner(userId) || isParentOfChild(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    // Activity Subcollection (Events)
    match /activity/{userId}/events/{eventId} {
      allow read: if isOwner(userId) || isParentOfChild(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    // Lessons Collection
    match /lessons/{lessonId} {
      allow read: if true; // Anyone can read lessons
      allow write: if isAdmin(); // Only admins can create/update lessons
      
      // AI Contents Subcollection
      match /ai_contents/{contentId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    // Shared math question bank parsed from uploaded exams
    match /questionSets/{questionSetId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /questions/{questionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /questionBank/{questionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /questionBankMeta/{metaId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /questionAttempts/{attemptId} {
      allow create: if isKid()
        && request.resource.data.kidUid == request.auth.uid
        && request.resource.data.kidQuestionKey == request.auth.uid + "_" + request.resource.data.questionId;
      allow read: if isAuthenticated()
        && (resource.data.kidUid == request.auth.uid || isParentOfChild(resource.data.kidUid) || isAdmin());
      allow update, delete: if isAdmin();
    }

    match /kidQuestionStats/{kidQuestionKey} {
      allow create, update: if isKid()
        && request.resource.data.kidUid == request.auth.uid
        && request.resource.data.kidQuestionKey == kidQuestionKey;
      allow read: if isAuthenticated()
        && (resource.data.kidUid == request.auth.uid || isParentOfChild(resource.data.kidUid) || isAdmin());
      allow delete: if isAdmin();
    }

    // Per-student parsed uploads
    match /studentSubmissions/{submissionId} {
      allow read: if isAuthenticated()
        && (resource.data.uid == request.auth.uid || isParentOfChild(resource.data.uid) || isAdmin());
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAuthenticated()
        && (resource.data.uid == request.auth.uid || isAdmin());
    }

    match /parseJobs/{jobId} {
      allow read: if isAuthenticated()
        && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated()
        && (!("uid" in request.resource.data) || request.resource.data.uid == request.auth.uid || isAdmin());
      allow update, delete: if isAuthenticated()
        && (resource.data.uid == request.auth.uid || isAdmin());
    }

    // Personalized learning progress is written by trusted server APIs.
    match /studentProgress/{childId} {
      allow read: if isOwner(childId) || isParentOfChild(childId) || isAdmin();
      allow write: if isAdmin();
    }

    match /studentLessonProgress/{progressId} {
      allow read: if isAuthenticated()
        && (resource.data.childUid == request.auth.uid || isParentOfChild(resource.data.childUid) || isAdmin());
      allow write: if isAdmin();
    }

    match /studentLessonCompletions/{attemptId} {
      allow read: if isAuthenticated()
        && (resource.data.childUid == request.auth.uid || isParentOfChild(resource.data.childUid) || isAdmin());
      allow write: if isAdmin();
    }

    match /studentExerciseAttempts/{attemptId} {
      allow read: if isAuthenticated()
        && (resource.data.childUid == request.auth.uid || isParentOfChild(resource.data.childUid) || isAdmin());
      allow write: if isAdmin();
    }

    match /studentPersonalizedPlans/{childId} {
      allow read: if isOwner(childId) || isParentOfChild(childId) || isAdmin();
      allow write: if isAdmin();
    }

    match /courses/{courseId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /coursePipelines/{pipelineId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /studentCourseRuns/{runId} {
      allow read: if isAuthenticated()
        && (resource.data.childUid == request.auth.uid || isParentOfChild(resource.data.childUid) || isAdmin());
      allow write: if isAdmin();
    }
  }
}
