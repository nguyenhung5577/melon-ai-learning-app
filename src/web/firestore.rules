rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }
    
    function isAdmin() {
      // In a real app, this would check a custom claim or a secure admin collection
      // For MVP, we'll assume any authenticated user can act as admin for lessons/content
      return isAuthenticated();
    }

    // Users Collection (Profile Data)
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
    }

    // Children Profile Collection
    match /children/{childId} {
      // Allow read/write if the child ID is the authenticated user's ID
      // This supports the simple 1:1 user-to-child model we have for MVP
      allow read, write: if isOwner(childId);
    }

    // Gamification Collection
    match /gamification/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Activity Subcollection (Events)
    match /activity/{userId}/events/{eventId} {
      allow read, write: if isOwner(userId);
    }

    // Lessons Collection
    match /lessons/{lessonId} {
      allow read: if true; // Anyone can read lessons
      allow write: if isAdmin(); // Only admins can create/update lessons
      
      // AI Contents Subcollection
      match /ai_contents/{contentId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }
  }
}
